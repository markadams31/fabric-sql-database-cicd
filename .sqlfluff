# SQLFluff -- style linting for the T-SQL source (the .sql files under databases/).
#
# SQLFluff runs its whole rule set by default; the sections below pin the *policies* this
# repo enforces so the intent is visible rather than implicit. Layout rules (spacing,
# indentation, commas) are on by default and need no configuration.
#
# Full rule reference: https://docs.sqlfluff.com/en/stable/reference/rules.html
# Run it:  sqlfluff lint databases   (the pre-commit hook runs it for you)

[sqlfluff]
dialect = tsql
# Schema files are not templated; the raw templater avoids interpreting braces as Jinja.
templater = raw
max_line_length = 120

# --- Capitalisation: keep the T-SQL uniform and scannable ---
[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

# --- Conventions ---
[sqlfluff:rules:convention.terminator]
# Every statement ends with a semicolon (not just the batch).
require_final_semicolon = true


# =========================================================================================
# OPTIONAL -- stricter or more opinionated rules. Uncomment any your team wants; each is a
# real SQLFluff rule (see the reference link above). Turning these on is how you tighten
# the house style beyond SQLFluff's defaults.
# =========================================================================================

# Enforce a case for UNQUOTED identifiers. Inert here (every identifier is bracketed), but
# useful the moment someone writes an unbracketed name:
# [sqlfluff:rules:capitalisation.identifiers]
# extended_capitalisation_policy = lower

# Prefer ANSI "<>" over "!=" for not-equal:
# [sqlfluff:rules:convention.not_equal]
# preferred_not_equal_style = ansi

# Consistent quoting for string literals:
# [sqlfluff:rules:convention.quoted_literals]
# preferred_quoted_literal_style = single_quotes

# Consistent cast style -- CAST(x AS t) rather than the shorthand:
# [sqlfluff:rules:convention.casting_style]
# preferred_type_casting_style = cast

# Ban specific words as identifiers -- e.g. reserve names you consider legacy:
# [sqlfluff:rules:convention.blocked_words]
# blocked_words = sysname,timestamp

# Require every column reference to be qualified (matters once you add views/procedures
# that join multiple tables):
# [sqlfluff:rules:references.qualification]
