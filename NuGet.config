<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Pin the package source for reproducible restores of the SQL project SDK
       (Microsoft.Build.Sql) and its DacFx dependencies on any machine, including CI. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
